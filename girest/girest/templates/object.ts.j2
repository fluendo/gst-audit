{# Object template - handles GIR object types (GObject-derived classes) #}
{% extends "base.ts.j2" %}

{# Set the schema variable for the base template #}
{% set schema = object %}

{# Override imports block to call parent with our variable set #}
{% block imports %}
{{ super() }}
{% endblock %}

{% block content %}

{% block finalization%}
{% if object.parent_schema.info_type == 'struct' %}
{% set registry_name = object.name.lower() + 'Registry' %}
// Finalization registry for {{ object.name }}
const {{ registry_name }} = new FinalizationRegistry((ptr: string) => {
  fetch(apiConfig.fullBaseUrl + '/{{ object.namespace }}/{{ object.type_name }}/ptr,' + ptr + '/unref')
    .catch(err => console.error('Failed to free {{ object.name }}:', ptr, err));
});
{% endif %}
{% endblock %}

{% block signature %}
export class {{ object.name }}{% if object.parent_schema %} extends {{ object.parent_schema.valid_name }}{% endif %} {
{% endblock %}

{% block constructors %}
  {% block default_constructor %}
    {% if object.parent_schema.info_type == 'struct' %}

  protected constructor(ptr: string, transferType: transferType) {
  super(ptr, 'none');
    {{ object.name.lower() }}Registry.register(this, ptr);
    // Don't ref in constructor - use static create() method instead
  }

  static async create(ptr: string, transferType: transferType): Promise<{{ object.name }}> {
    const instance = new {{ object.name }}(ptr, transferType);
    if (transferType === 'none') {
      await instance.ref();
    }
    return instance;
  }
    {% elif object.parent_schema and object.parent_schema.info_type == 'object' %}

  // Override parent's create() to return correct type
  static async create(ptr: string, transferType: transferType): Promise<{{ object.name }}> {
    const instance = new {{ object.name }}(ptr, transferType);
    if (transferType === 'none') {
      await instance.ref();
    }
    return instance;
  }
    {% endif %}
  {% endblock %}

  {% for constructor in object.constructors %}
    {{ constructor.generate() }}
  {% endfor %}
{% endblock %}

{% block destructors %}
  {% for destructor in object.destructors %}
      {{ destructor.generate() }}
  {% endfor %}
{% endblock%}

{% block methods %}
  {% for method in object.methods %}
      {{ method.generate() }}
  {% endfor %}
{% endblock %}
}

{% endblock %} {# End content block #}
